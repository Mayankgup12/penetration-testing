{
  "app": {
    "secret_key_env": "PTF_SECRET_KEY",
    "default_secret_key": "change-me-in-production-use-env",
    "host": "127.0.0.1",
    "port": 5000,
    "threaded": true
  },
  "server": {
    "use_waitress": true,
    "waitress_threads": 8,
    "waitress_channel_timeout": 120,
    "waitress_cleanup_interval": 30
  },
  "http": {
    "timeout_seconds": 15,
    "max_retries": 3,
    "retry_backoff_seconds": 1.5,
    "user_agent": "PTF-EducationalScanner/1.0 (+ethical-use-only)",
    "rate_limit_seconds": 0.35
  },
  "recon": {
    "max_crawl_pages": 40,
    "max_url_length": 2048,
    "common_ports": [80, 443, 8080, 8443, 8000, 3000],
    "port_scan_timeout": 1.5
  },
  "scanner": {
    "max_param_tests_per_url": 25,
    "sqli_payloads": [
      "' OR '1'='1",
      "1' AND '1'='1",
      "admin'--",
      "1 AND 1=1",
      "' UNION SELECT NULL--"
    ],
    "xss_payloads": [
      "<script>alert(1)</script>",
      "\"><img src=x onerror=alert(1)>",
      "'-alert(1)-'"
    ]
  },
  "storage": {
    "scans_dir": "data/scans",
    "scan_history_file": "data/scan_history.json",
    "users_file": "data/users.json"
  },
  "logging": {
    "level": "INFO",
    "file": "data/logs/ptf.log",
    "max_bytes": 10485760,
    "backup_count": 5
  },
  "scan_executor": {
    "max_workers": 4
  }
}
